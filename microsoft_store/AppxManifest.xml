<?xml version="1.0" encoding="utf-8"?>
<Package
  xmlns="http://schemas.microsoft.com/appx/manifest/foundation/windows10"
  xmlns:uap="http://schemas.microsoft.com/appx/manifest/uap/windows10"
  xmlns:rescap="http://schemas.microsoft.com/appx/manifest/foundation/windows10/restrictedcapabilities"
  xmlns:desktop="http://schemas.microsoft.com/appx/manifest/desktop/windows10"
  IgnorableNamespaces="uap rescap desktop">

  <!--
    ╔══════════════════════════════════════════════════════════════╗
    ║  PARTNER CENTER PRODUCT IDENTITY                            ║
    ║  Replace the 3 PLACEHOLDER values below with the real       ║
    ║  values from Partner Center → Product Identity page.        ║
    ╚══════════════════════════════════════════════════════════════╝
  -->
  <Identity
    Name="MaherBhatt.Kalki"
    Publisher="CN=5077752A-5182-4523-A5DB-4EBB2626926D"
    Version="1.0.25.0"
    ProcessorArchitecture="x64" />

  <Properties>
    <DisplayName>Kalki</DisplayName>
    <PublisherDisplayName>Maher Bhatt</PublisherDisplayName>
    <Logo>Assets\StoreLogo.png</Logo>
    <Description>KALKI - Your intelligent AI desktop assistant.</Description>
  </Properties>

  <Dependencies>
    <TargetDeviceFamily Name="Windows.Desktop"
      MinVersion="10.0.17763.0"
      MaxVersionTested="10.0.26100.0" />
  </Dependencies>

  <Resources>
    <Resource Language="en-us" />
  </Resources>

  <Applications>
    <Application Id="KALKI"
      Executable="KALKI.exe"
      EntryPoint="Windows.FullTrustApplication">
      <Extensions>
        <desktop:Extension Category="windows.startupTask" Executable="KALKI.exe" EntryPoint="Windows.FullTrustApplication">
          <desktop:StartupTask TaskId="KalkiStartupTask" Enabled="true" DisplayName="Kalki AI Assistant" />
        </desktop:Extension>
      </Extensions>

      <uap:VisualElements
        DisplayName="Kalki"
        Description="KALKI - AI Desktop Assistant with voice control, smart automation, cybersecurity tools, Spotify, email, calendar, and more."
        BackgroundColor="#1a1a2e"
        Square150x150Logo="Assets\Square150x150Logo.png"
        Square44x44Logo="Assets\Square44x44Logo.png">

        <uap:DefaultTile
          Wide310x150Logo="Assets\Wide310x150Logo.png"
          Square71x71Logo="Assets\Square71x71Logo.png"
          ShortName="Kalki" />

        <uap:SplashScreen
          Image="Assets\SplashScreen.png"
          BackgroundColor="#1a1a2e" />

      </uap:VisualElements>
    </Application>
  </Applications>

  <Capabilities>
    <Capability Name="internetClient" />
    <Capability Name="internetClientServer" />
    <rescap:Capability Name="runFullTrust" />
    <DeviceCapability Name="microphone" />
  </Capabilities>

</Package>
